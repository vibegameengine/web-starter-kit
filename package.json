{
  "name": "web-starter-kit",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Opinionated Vite + React + TypeScript starter kit distilled from a production browser game: custom build-time optimizers, an auto-collected asset preloader, and a two-stage readiness gate.",
  "scripts": {
    "dev": "vite",
    "postinstall": "node scripts/link-agent-skills.ts",
    "build": "tsc -b && vite build",
    "build:gh-pages": "VITE_BASE_PATH=/web-starter-kit/ npm run build",
    "preview": "vite preview",
    "lint": "eslint .",
    "knip": "knip --include files,exports",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "version:bump": "node scripts/bump-version.ts",
    "version:major": "node scripts/bump-version.ts major",
    "version:minor": "node scripts/bump-version.ts minor",
    "version:patch": "node scripts/bump-version.ts patch"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@vibegameengine/shader-warmup": "^1.0.3",
    "@vibegameengine/ui-scaler": "^1.0.2",
    "howler": "^2.2.4",
    "photon-realtime": "^4.4.0",
    "r3f-perf": "^7.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.18.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/howler": "^2.2.13",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fbx2gltf": "^0.9.7-p1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "knip": "^6.1.1",
    "lamejs": "^1.2.1",
    "meshoptimizer": "^1.2.0",
    "mpg123-decoder": "^1.0.3",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-imagetools": "^10.0.0",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vitest": "^4.1.0"
  }
}
